# Port the gateway listens on (defaults to 8787 if unset).
PORT=8787

# LiteLLM connection.
# - `npm run dev` (host process): reach LiteLLM via its published host port, so
#   use localhost — this is the value below.
# - Docker (compose): the container reaches LiteLLM over `webnet` by name; the
#   compose files override this to http://litellm:4000/v1, so leave it as-is.
LITELLM_BASE_URL=http://localhost:4000/v1
# Recommended: a LiteLLM virtual key (sk-...), not the master key.
LITELLM_API_KEY=

# Optional shared secret the Next.js app must send (X-Gateway-Key header) so only
# it can call this gateway. Leave unset to disable the check (e.g. local dev).
GATEWAY_API_KEY=
