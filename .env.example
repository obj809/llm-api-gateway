# Port the gateway listens on (defaults to 8787 if unset).
PORT=8787

# LiteLLM connection.
# - `npm run dev` (host process): reach LiteLLM via its published host port, so
#   use localhost — this is the value below.
# - Docker (compose): the container reaches LiteLLM over `webnet` by name; the
#   compose files override this to http://litellm:4000/v1, so leave it as-is.
LITELLM_BASE_URL=http://localhost:4000/v1
# Recommended: a LiteLLM virtual key (sk-...), not the master key. Used for every
# model except those listed in OLLAMA_MODELS below.
LITELLM_API_KEY=

# Optional second LiteLLM key used ONLY for the models in OLLAMA_MODELS, so the
# local Ollama models carry a separately-scoped key from the paid cloud models.
# Leave unset to route every model through LITELLM_API_KEY (unchanged behavior).
LITELLM_OLLAMA_API_KEY=
# Comma-separated models that should use LITELLM_OLLAMA_API_KEY. The route still
# forwards the model name to LiteLLM verbatim — this only picks which key to send.
OLLAMA_MODELS=llama3.2,deepseek-r1

# Optional shared secret the Next.js app must send (X-Gateway-Key header) so only
# it can call this gateway. Leave unset to disable the check (e.g. local dev).
GATEWAY_API_KEY=
