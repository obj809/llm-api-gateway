# Port the gateway listens on (defaults to 8787 if unset).
PORT=8787

# LiteLLM connection. On the VPS the gateway runs on the `webnet` Docker network
# and reaches the LiteLLM container directly by name — no nginx hop, LiteLLM
# stays internal-only. Locally, point this at wherever LiteLLM is reachable.
LITELLM_BASE_URL=http://litellm:4000/v1
LITELLM_API_KEY=

# Optional shared secret the Next.js app must send (X-Gateway-Key header) so only
# it can call this gateway. Leave unset to disable the check (e.g. local dev).
GATEWAY_API_KEY=
